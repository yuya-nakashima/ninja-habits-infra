{
  "compilerOptions": {
    "target":              "ES2020",
    "lib":                 ["es2020"],
    "module":              "commonjs",
    "moduleResolution":    "node",
    "strict":              true,
    "esModuleInterop":     true,
    "skipLibCheck":        true,
    "outDir":              "dist"
  },
  "exclude": ["node_modules", "cdk.out", "dist"]
}
